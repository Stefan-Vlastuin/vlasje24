# Kopieer dit bestand naar .env en vul de waarden in.
# .env wordt NOOIT gecommit (staat in .gitignore).

# MySQL root-wachtwoord (alleen voor interne DB-initialisatie)
MYSQL_ROOT_PASSWORD=

# Wachtwoord voor de applicatie-gebruiker (vlasje24_app)
MYSQL_APP_PASSWORD=

# JWT-signing secret — minimaal 32 tekens, zo lang en willekeurig mogelijk
JWT_SECRET=

# Domeinnaam voor productie (zonder https://)
DOMAIN=jouwdomein.nl

# Docker Hub gebruikersnaam (voor bouwen en pushen van images)
DOCKER_USERNAME=jouw-dockerhub-naam
